# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Demo Account Passwords (Backend only - NEVER in frontend .env)
# These should only be in your backend .env, not in frontend
# DEMO_PASSWORD_SUPERADMIN_INCIDENTDESK_COM=Test1234!
# DEMO_PASSWORD_ADMIN_ACMECORP_COM=Test1234!
# DEMO_PASSWORD_AGENTE_ACMECORP_COM=Test1234!
# DEMO_PASSWORD_DEV_ACMECORP_COM=Test1234!

# Note: Copy this to .env and fill in your actual values
# IMPORTANT: .env is in .gitignore and should never be committed
